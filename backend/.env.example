# Ortam değişkenlerini buraya kopyala ve .env olarak kaydet

DATABASE_URL=sqlite+aiosqlite:///./avukat_oyunu.db
# Production için Supabase PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

SECRET_KEY=supersecretkey-change-this-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# HuggingFace API (ücretsiz, https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ollama (lokal geliştirme)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Frontend URL (CORS için)
FRONTEND_URL=http://localhost:5173
